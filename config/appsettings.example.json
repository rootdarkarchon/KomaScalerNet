{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://127.0.0.1:9999"
      }
    }
  },
  "Upscaling": {
    "Models": {
      "Directory": "/var/lib/komascaler/models",
      "InventoryFile": "models.production.json",
      "CudaDeviceId": 0,
      "TensorRtCacheDirectory": "/var/cache/komascaler/tensorrt",
      "TensorRtVersion": "10.14",
      "TensorRtMaxWorkspaceBytes": 2147483648,
      "TensorRtAuxiliaryStreams": 0,
      "TensorRtContextMemorySharing": true,
      "TensorRtTimingCache": true,
      "TensorRtProfileOptimumExtent": 960,
      "TensorRtProfileMaximumExtent": 960,
      "PreloadOnStartup": true,
      "IdleSessionUnloadAfter": "00:10:00"
    },
    "Tiling": {
      "MaximumCoreSize": 832,
      "ContextPixelsPerSide": 64,
      "LowMemoryMaximumCoreSize": 192,
      "LowMemoryContextPixelsPerSide": 16
    },
    "Queue": {
      "Capacity": 8,
      "AdmissionTimeout": "00:00:00.100",
      "ResponseDeadline": "00:00:28"
    },
    "Input": {
      "MaxUploadBytes": 67108864,
      "MaxDecodedPixels": 80000000,
      "MonochromeThreshold": 12
    },
    "Output": {
      "Format": "png",
      "Lossless": true,
      "Quality": 100,
      "Effort": 2,
      "PngCompression": 3
    },
    "Cache": {
      "Directory": "/var/cache/komascaler",
      "MaximumBytes": 107374182400,
      "MaximumAge": "90.00:00:00",
      "CleanupInterval": "01:00:00"
    },
    "Security": {
      "TokenHeader": "X-Upscaler-Token",
      "Token": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
